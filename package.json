{
  "name": "gitsouji",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "1.5.1",
  "publisher": "badfalcon",
  "license": "MIT",
  "icon": "images/icon.png",
  "readme": "STORE.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/badfalcon/gitbranchcleaner.git"
  },
  "homepage": "https://github.com/badfalcon/gitbranchcleaner#readme",
  "bugs": {
    "url": "https://github.com/badfalcon/gitbranchcleaner/issues"
  },
  "keywords": [
    "git",
    "branch",
    "cleaner",
    "cleanup",
    "dead",
    "stale",
    "scm",
    "source control",
    "souji",
    "sohji"
  ],
  "engines": {
    "vscode": "^1.106.1"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "commands": [
      {
        "command": "gitsouji.openCleaner",
        "title": "%command.openCleaner.title%",
        "icon": "$(sparkle)"
      },
      {
        "command": "gitsouji.queue.execute",
        "title": "%command.queue.execute.title%",
        "category": "Git Sohji",
        "icon": "$(play)"
      },
      {
        "command": "gitsouji.queue.clear",
        "title": "%command.queue.clear.title%",
        "category": "Git Sohji",
        "icon": "$(clear-all)"
      },
      {
        "command": "gitsouji.queue.removeItem",
        "title": "%command.queue.removeItem.title%",
        "category": "Git Sohji",
        "icon": "$(close)"
      },
      {
        "command": "gitsouji.switchRepository",
        "title": "%command.switchRepository.title%",
        "category": "Git Sohji",
        "icon": "$(repo)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gitsouji",
          "title": "%viewsContainers.gitsouji.title%",
          "icon": "media/activity-bar-icon.svg"
        }
      ]
    },
    "views": {
      "gitsouji": [
        {
          "id": "gitsouji.deletionQueue",
          "name": "%view.deletionQueue.name%"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "gitsouji.deletionQueue",
        "contents": "%viewsWelcome.deletionQueue.empty%"
      }
    ],
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "gitSouji.baseBranch": {
          "order": 1,
          "type": "string",
          "default": "auto",
          "markdownDescription": "%config.baseBranch.description%"
        },
        "gitSouji.staleDays": {
          "order": 2,
          "type": "number",
          "default": 30,
          "minimum": 1,
          "description": "%config.staleDays.description%"
        },
        "gitSouji.autoFetchPrune": {
          "order": 3,
          "type": "boolean",
          "default": false,
          "markdownDescription": "%config.autoFetchPrune.description%"
        },
        "gitSouji.detectParentMerges": {
          "order": 4,
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.detectParentMerges.description%"
        },
        "gitSouji.protectedBranches": {
          "order": 10,
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "main",
            "master",
            "develop"
          ],
          "markdownDescription": "%config.protectedBranches.description%"
        },
        "gitSouji.confirmBeforeDelete": {
          "order": 20,
          "type": "boolean",
          "default": true,
          "description": "%config.confirmBeforeDelete.description%"
        },
        "gitSouji.forceDeleteLocal": {
          "order": 21,
          "type": "boolean",
          "default": false,
          "markdownDescription": "%config.forceDeleteLocal.description%"
        },
        "gitSouji.allowRemoteBranchDeletion": {
          "order": 22,
          "type": "boolean",
          "default": false,
          "description": "%config.allowRemoteBranchDeletion.description%"
        },
        "gitSouji.includeRemoteInDeadCleanup": {
          "order": 23,
          "type": "boolean",
          "default": false,
          "description": "%config.includeRemoteInDeadCleanup.description%"
        },
        "gitSouji.showStatusBadges": {
          "order": 30,
          "type": "boolean",
          "default": true,
          "description": "%config.showStatusBadges.description%"
        }
      }
    },
    "menus": {
      "scm/title": [
        {
          "command": "gitsouji.openCleaner",
          "group": "navigation@10",
          "when": "scmProvider == git"
        }
      ],
      "view/title": [
        {
          "command": "gitsouji.queue.execute",
          "when": "view == gitsouji.deletionQueue",
          "group": "navigation@1"
        },
        {
          "command": "gitsouji.queue.clear",
          "when": "view == gitsouji.deletionQueue",
          "group": "navigation@2"
        },
        {
          "command": "gitsouji.switchRepository",
          "when": "view == gitsouji.deletionQueue",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "gitsouji.queue.removeItem",
          "when": "view == gitsouji.deletionQueue && (viewItem == queueItemPending || viewItem == queueItemDone) && !gitsouji.queueExecuting",
          "group": "inline"
        }
      ],
      "commandPalette": [
        {
          "command": "gitsouji.queue.execute",
          "when": "gitsouji.queueHasItems"
        },
        {
          "command": "gitsouji.queue.clear",
          "when": "gitsouji.queueHasItems"
        },
        {
          "command": "gitsouji.queue.removeItem",
          "when": "false"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/sinon": "^21.0.0",
    "@types/vscode": "^1.106.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.1",
    "sinon": "^21.0.1",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "webpack": "^5.103.0",
    "webpack-cli": "^6.0.1"
  }
}
